#!/usr/bin/env python3
from sys import argv as args
from subprocess import Popen,PIPE
def get_curr_layout():
    return Popen(['setxkbmap','-query'],stdout=PIPE).stdout.read().decode().strip().splitlines()[2].strip().split()[1]
match args[1]:
    case "query":
        print(get_curr_layout())
    case "toggle":
        layouts=['us','hu']
        Popen(['setxkbmap','-layout',layouts[(layouts.index(get_curr_layout())+1)%len(layouts)]])
    case _:
        exit(1)

