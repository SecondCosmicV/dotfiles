#!/usr/bin/env python3
import os
import sys
from subprocess import PIPE,Popen
import signal
from time import sleep
from datetime import datetime
class PulseModule:
    def __init__(self,typ):
        self.typ=typ
    def update(self):
        outs=[Popen([
            'pactl',
            f'get-{self.typ}-{x}',
            '@DEFAULT_{}@'.format(self.typ.upper())
        ],stdout=PIPE).stdout.read().decode() for x in ['volume','mute']]
        self.display=''.join([
            outs[0].split()[4][:-1],
            'u' if 'nein' in outs[1] else 'm',
        ])
class KeyboardModule:
    def __init__(self):
        pass
    def update(self):
        self.display=Popen(['kytool','query'],stdout=PIPE).stdout.read().decode().strip()
class BrightnessModule:
    def __init__(self):
        pass
    def update(self):
        self.display=Popen(['brightnessctl'],stdout=PIPE).stdout.read().decode().splitlines()[1].strip().split()[3][1:-2]
class BatteryModule:
    def __init__(self):
        pass
    def update(self):
        a=Popen(['acpi'],stdout=PIPE).stdout.read().decode().strip().split(': ')[1].split(', ')
        self.display=a[1][:-1]+a[0][0].lower()
class TimeModule:
    def __init__(self):
        pass
    def update(self):
        time_string=datetime.now().astimezone().isoformat(' ')
        dot_idx=time_string.find('.')
        self.display='{} (UTC{})'.format(time_string[:dot_idx],time_string[dot_idx+7:])
modules=[
    (PulseModule('source'),'srce',10),
    (PulseModule('sink'),'sink',10),
    (KeyboardModule(),'keyb',10),
    (BrightnessModule(),'brig',10),
    (BatteryModule(),'bat',10),
    (TimeModule(),'earth',1),
]
def refresh(i):
    for module,label,period_s in modules:
        if not (i%period_s):
            module.update()
    sys.stdout.write(' | '.join(map(lambda x:'{}: {}'.format(x[1],x[0].display),modules))+'\n')
    sys.stdout.flush()
with open('/tmp/status.pid','w') as f:
    f.write(str(os.getpid()))
signal.signal(signal.SIGUSR1,lambda signum,stack:refresh(0))
i=0
while True:
    refresh(i)
    sleep(1)
    i+=1

