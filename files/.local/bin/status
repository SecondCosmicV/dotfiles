#!/usr/bin/env python3
import os
import sys
from subprocess import PIPE,Popen
import signal
from time import time,sleep
from datetime import datetime
from contextlib import suppress
class NetModule:
    def __init__(self):
        self.interf=next(filter(lambda x:x[1]=='wifi',map(
            lambda x:x.strip().split(':'),
            Popen(['nmcli','-t','-f','DEVICE,TYPE','device'],stdout=PIPE).stdout.read().decode().splitlines(),
        )))[0]
        self.curr_bytes=[0,0]
        self.curr_upd_ts=0
    def update(self):
        prev_bytes=tuple(self.curr_bytes)
        prev_upd_ts=self.curr_upd_ts
        for i,x in enumerate('rt'):
            with open(f'/sys/class/net/{self.interf}/statistics/{x}x_bytes','r') as f:
                self.curr_bytes[i]=int(f.read())
        self.curr_upd_ts=time()
        self.display='v{:.3e} ^{:.3e}'.format(*map(
            lambda x:(self.curr_bytes[x]-prev_bytes[x])/(self.curr_upd_ts-prev_upd_ts),
            range(2),
        ))
class DiskModule:
    def __init__(self):
        self.device=Popen('lsblk -slno NAME $(df -h --output=source ~/stuff | tail -n 1) | tail -n 1',shell=True,stdout=PIPE).stdout.read().decode().strip()
        with open(f'/sys/block/{self.device}/queue/hw_sector_size','r') as f:
            self.bytes_per_sector=int(f.read())
        self.curr_sectors=(0,0)
        self.curr_upd_ts=0
    def update(self):
        prev_sectors=self.curr_sectors
        prev_upd_ts=self.curr_upd_ts
        with open('/proc/diskstats','r') as f:
            diskstats=next(filter(lambda x:x[2]==self.device,map(lambda x:x.split(),f)))
        self.curr_sectors=(int(diskstats[5]),int(diskstats[9]))
        self.curr_upd_ts=time()
        self.display='v{:.3e} ^{:.3e}'.format(*map(
            lambda x:(self.curr_sectors[x]-prev_sectors[x])*self.bytes_per_sector/(self.curr_upd_ts-prev_upd_ts),
            range(2),
        ))
class PulseModule:
    def __init__(self,typ):
        self.typ=typ
    def update(self):
        outs=[Popen([
            'pactl',
            f'get-{self.typ}-{x}',
            '@DEFAULT_{}@'.format(self.typ.upper())
        ],stdout=PIPE).stdout.read().decode() for x in ['volume','mute']]
        self.display=''.join([
            outs[0].split()[4][:-1],
            'u' if 'nein' in outs[1] else 'm',
        ])
class BrightnessModule:
    def __init__(self):
        pass
    def update(self):
        self.display=Popen(['brightnessctl'],stdout=PIPE).stdout.read().decode().splitlines()[1].strip().split()[3][1:-2]
class TemperatureModule:
    def __init__(self):
        pass
    def update(self):
        self.display=str(int(float(next(filter(
            lambda x:x.startswith('thinkpad-isa-0000'),
            Popen(['sensors'],stdout=PIPE).stdout.read().decode().split('\n\n'),
        )).splitlines()[3].split()[1][:-2])))
class CPUModule:
    def __init__(self):
        self.curr=(0,0)
    def update(self):
        prev=self.curr
        with open('/proc/stat','r') as f:
            fields=list(map(int,f.readline().split()[1:]))
        self.curr=(
            fields[3],
            sum(fields),
        )
        self.display=str(int(100*(1-(self.curr[0]-prev[0])/(self.curr[1]-prev[1]))))
class RAMModule:
    def __init__(self):
        pass
    def update(self):
        self.display=Popen(['free','-h','--si'],stdout=PIPE).stdout.read().decode().splitlines()[1].split()[2]
class BatteryModule:
    def __init__(self):
        pass
    def update(self):
        a=Popen(['acpi'],stdout=PIPE).stdout.read().decode().strip().split(': ')[1].split(', ')
        self.display=a[1][:-1]+a[0][0].lower()
class KeyboardModule:
    def __init__(self):
        pass
    def update(self):
        self.display=Popen(['kblm','query'],stdout=PIPE).stdout.read().decode().strip()
class TimeModule:
    def __init__(self):
        pass
    def update(self):
        time_string=datetime.now().astimezone().isoformat(' ')
        dot_idx=time_string.find('.')
        self.display='{} (UTC{})'.format(time_string[:dot_idx],time_string[dot_idx+7:])
modules=[
    (NetModule(),'net',2),
    (DiskModule(),'disk',2),
    (PulseModule('source'),'srce',10),
    (PulseModule('sink'),'sink',10),
    (BrightnessModule(),'brig',10),
    (TemperatureModule(),'temp',10),
    (CPUModule(),'cpu',2),
    (RAMModule(),'ram',2),
    (BatteryModule(),'bat',10),
    (KeyboardModule(),'keyb',10),
    (TimeModule(),'earth',1),
]
def refresh(i):
    for module,label,period_s in modules:
        if not (i%period_s):
            module.update()
    sys.stdout.write(' | '.join(map(lambda x:'{}: {}'.format(x[1],x[0].display),modules))+'\n')
    sys.stdout.flush()
with open('/tmp/status.pid','w') as f:
    f.write(str(os.getpid()))
signal.signal(signal.SIGUSR1,lambda signum,stack:refresh(0))
i=0
while True:
    with suppress(Exception):
        refresh(i)
    sleep(1)
    i+=1

