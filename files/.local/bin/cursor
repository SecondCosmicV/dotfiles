#!/usr/bin/env bash

mkdir -p ~/.cursor
mkdir -p ~/.config/Cursor
mkdir -p ~/stuff/dev/_cursor
touch /tmp/link.txt
exec guix shell \
    -p ~/stuff/roots/cursor \
    --container \
    --emulate-fhs \
    --no-cwd \
    --network \
    --preserve="^DISPLAY$" \
    --preserve='^DBUS_SESSION_BUS_ADDRESS$' \
    --expose="$XAUTHORITY" \
    --expose=/var/run/dbus/system_bus_socket \
    --expose=$(ls /tmp/dbus-*) \
    --expose=$HOME/.local/bin/xdg-open-hack=$HOME/.local/bin/firefox \
    --share=/dev/shm \
    --share=$HOME/.cursor \
    --share=$HOME/.config/Cursor \
    --share=$HOME/stuff/dev/_cursor \
    --share=/tmp/link.txt \
    -- \
    bash \
    -c \
    "export PATH=\"\$HOME/.local/bin:\$PATH\" && exec cursor"

